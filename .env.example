# 8Router Environment Variables
# Copy to .env and fill in your values

# ══════════════════════════════════════════════
# TUNNEL (Phase 1)
# ══════════════════════════════════════════════
TUNNEL_ENABLED=false
TUNNEL_PROVIDER=cloudflare        # cloudflare | ngrok | manual
TUNNEL_AUTH_REQUIRED=true
TUNNEL_TOKEN=                     # auto-generated if empty
TUNNEL_PUBLIC_URL=                # set by provider or manual
CLOUDFLARE_TUNNEL_TOKEN=          # for cloudflare provider
NGROK_AUTHTOKEN=                  # for ngrok provider

# ══════════════════════════════════════════════
# OAUTH (Phase 2)
# ══════════════════════════════════════════════
OAUTH_ENABLED=false
OAUTH_PROVIDER=none               # none | google | github | both
OAUTH_ALLOWED_EMAILS=             # comma-separated
OAUTH_ALLOWED_DOMAINS=            # comma-separated
SESSION_SECRET=                   # auto-generated if empty
SESSION_MAX_AGE_HOURS=24

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ══════════════════════════════════════════════
# Redirect URIs (set these in your OAuth provider)
# ══════════════════════════════════════════════
# Google:  http://localhost:8080/auth/google/callback
# GitHub:  http://localhost:8080/auth/github/callback
# Public:  https://YOUR-TUNNEL-URL/auth/google/callback
#          https://YOUR-TUNNEL-URL/auth/github/callback

# ══════════════════════════════════════════════
# i18n (Phase 3)
# ══════════════════════════════════════════════
DEFAULT_LOCALE=en                # en | id | ja
SUPPORTED_LOCALES=en,id,ja
